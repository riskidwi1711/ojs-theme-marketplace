# =====================
# Production Environment Configuration
# =====================
# Copy this file to .env and fill in your production values
# =====================

# Application Configuration
appName=ojs-theme-marketplace
address=0.0.0.0
port=4000
env=production
TZ=Asia/Jakarta

app.baseUrl=https://openthemes.riski-labs.site

# MongoDB Configuration
sa.mongodb.uri=mongodb://<username>:<password>@<host>:<port>/ojs-marketplace?authSource=admin

# PostgreSQL Configuration (Blade DB)
postgresql.username=<username>
postgresql.password=<password>
postgresql.db=<database_name>
postgresql.schema=public
postgresql.host=<host>
postgresql.port=5432
postgresql.minIdleConnections=2
postgresql.maxOpenConnections=20
postgresql.maxLifetime=3600
postgresql.logMode=false

# JWT Configuration - GENERATE NEW SECRETS FOR PRODUCTION!
jwt.secret=<generate-32-char-random-string>
jwt.key=<generate-32-char-random-string>
jwt=<generate-32-char-random-string>

# Hash Key for Password Encryption - GENERATE NEW SECRET!
hashKey=<generate-32-char-random-string>

# System Logger Configuration
logger.sys.stdout=true
logger.sys.fileLocation=./logs/system.log
logger.sys.fileMaxAge=7
logger.sys.mask=false

# TDR Logger Configuration
logger.tdr.stdout=true
logger.tdr.fileLocation=./logs/tdr.log
logger.tdr.fileMaxAge=7
logger.tdr.mask=false

# Xendit Payment Gateway Configuration
xendit.api.host=https://api.xendit.co
xendit.api.keyName=ojs-marketplace
xendit.api.keyToken=<your-xendit-secret-key>
xendit.api.debug=false
xendit.api.successRedirectURL=https://openthemes.riski-labs.site/checkout/confirmation?orderId=:orderId
xendit.api.failureRedirectURL=https://openthemes.riski-labs.site/checkout/confirmation?orderId=:orderId

# Telegram Bot Configuration
telegram.bot.token=<your-telegram-bot-token>
telegram.group.id=<your-group-id>
telegram.webhook.secret=<your-webhook-secret>

# MinIO Object Storage Configuration
minio.endpoint=<minio-host>:9000
minio.accessKeyID=<access-key>
minio.secretAccessKey=<secret-key>
minio.bucketName=ojs-marketplace
minio.useSSL=true
minio.region=us-east-1

# Brevo Email Configuration
brevo.api.host=https://api.brevo.com/v3
brevo.email.senderName=OpenThemes
brevo.email.sender=no-reply@riski-labs.site
brevo.api.key=<your-brevo-api-key>
